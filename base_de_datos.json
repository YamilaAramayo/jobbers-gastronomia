

-- Tabla de Usuarios (Candidatos y Empresas)
CREATE TABLE IF NOT EXISTS usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(120) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    rol ENUM('postulante', 'empleador') NOT NULL,
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

-- Tabla de Ofertas Laborales / Vacantes
CREATE TABLE IF NOT EXISTS ofertas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    empresa_id INT NOT NULL,
    titulo VARCHAR(150) NOT NULL,
    empresa_nombre VARCHAR(120) NOT NULL,
    ubicacion VARCHAR(100) NOT NULL,
    tipo_jornada VARCHAR(50) NOT NULL,
    turno VARCHAR(50) NOT NULL,
    salario VARCHAR(80) DEFAULT 'A convenir',
    urgente TINYINT(1) DEFAULT 0,
    estado ENUM('activa', 'pausada', 'cerrada') DEFAULT 'activa',
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (empresa_id) REFERENCES usuarios(id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- Tabla de Postulaciones (Candidatos aplicando a ofertas)
CREATE TABLE IF NOT EXISTS postulaciones (
    id INT AUTO_INCREMENT PRIMARY KEY,
    oferta_id INT NOT NULL,
    candidato_id INT NOT NULL,
    mensaje TEXT,
    fecha_postulacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (oferta_id) REFERENCES ofertas(id) ON DELETE CASCADE,
    FOREIGN KEY (candidato_id) REFERENCES usuarios(id) ON DELETE CASCADE
) ENGINE=InnoDB;
